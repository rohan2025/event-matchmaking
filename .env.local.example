# =============================================================
# Event Matchmaking — environment variables
# Copy to `.env.local` and fill with values from YOUR personal accounts.
# Never commit .env.local (it is already gitignored).
# =============================================================

# ── Supabase (your personal project: Settings → API) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Email (Brevo SMTP — for OTP + match emails) ───────────────
# Create your own Brevo account → SMTP & API → SMTP credentials.
# Sender must be a verified sender/domain in Brevo, or emails won't send.
BREVO_SMTP_USER=your-login@smtp-brevo.com
BREVO_SMTP_PASS=your-brevo-smtp-key

# ── Admin password (simple gate used by some admin actions) ───
ADMIN_PASSWORD=choose-a-strong-password

# ── Groq (optional — chat feature) ───────────────────────────
GROQ_API_KEY=gsk_your_key_optional
